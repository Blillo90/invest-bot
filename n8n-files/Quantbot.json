    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst historyPath = '/home/node/.n8n-files/history.json';\n\nconst item = $input.first().json;\nconst txt = String(item.data || '');\nconst lines = txt.split('\\n').map(l => l.trim());\n\nconst findValue = (prefix) => {\n  const line = lines.find(l => l.toLowerCase().startsWith(prefix.toLowerCase()));\n  if (!line) return null;\n  const colonIdx = line.indexOf(':');\n  if (colonIdx === -1) return null;\n  return line.slice(colonIdx + 1).replace(/\\*\\*/g, '').trim();\n};\n\nconst parseNum = (v) => {\n  if (v === null || v === undefined) return null;\n  const n = Number(String(v).replace(/[$%,\\s]/g, ''));\n  return Number.isNaN(n) ? null : n;\n};\n\nconst entry = {\n  ts: new Date().toISOString(),\n  slot: item.session_label || 'UNKNOWN',\n  equityPre: parseNum(findValue('- Equity (pre)')),\n  equityPost: parseNum(findValue('- Equity (post)')),\n  cash: parseNum(findValue('- Cash')),\n  exposurePct: parseNum(findValue('- Exposición')),\n  drawdownPct: parseNum(findValue('- Drawdown (vs pico)')),\n  targetPerPos: parseNum(findValue('- Target por posición')),\n  rawLen: txt.length\n};\n\nlet history = [];\ntry {\n  const raw = fs.readFileSync(historyPath, 'utf8');\n  if (raw.trim()) history = JSON.parse(raw);\n} catch (e) {\n  history = [];\n}\n\nhistory.push(entry);\nfs.mkdirSync(path.dirname(historyPath), { recursive: true });\nfs.writeFileSync(historyPath, JSON.stringify(history, null, 2));\n\nreturn [{ json: item }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1408,
        -320
      ],
      "id": "c3d4e5f6-a7b8-9012-cdef-340123456789",
      "name": "Update History"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "f370def7-efba-42a1-b4b6-92a4a8bdb7da",
              "name": "subject",
              "value": "={{'QuantBot | ' + $json.session_label + ' | ' + $now.format('yyyy-LL-dd HH:mm') + ' NY'}}",
              "type": "string"
            },
            {
              "id": "e7802d8e-84f7-4ba0-a82c-b9e487e3b6fe",
              "name": "body",
              "value": "={{\n(() => {\n  const txt = String($json.data || \"\");\n  const lines = txt.split('\\n').map(l => l.trim());\n\n  const findValue = (startsWithText) => {\n    const line = lines.find(l => l.toLowerCase().startsWith(startsWithText.toLowerCase()));\n    if (!line) return \"\";\n    const parts = line.split(':');\n    return parts.length > 1 ? parts.slice(1).join(':').replace(/\\*\\*/g, '').replace(/\"/g, '').trim() : \"\";\n  };\n\n  const equity = findValue('- Equity (post)') || findValue('- Equity (pre)');\n  const cash = findValue('- Cash');\n  const exposure = findValue('- Exposición');\n  const drawdown = findValue('- Drawdown (vs pico)');\n\n  const formatMoney = (v) => {\n    const n = Number(String(v).replace(/,/g, '').replace(/\\$/g, '').trim());\n    if (Number.isNaN(n)) return v || '-';\n    return '$' + Math.round(n).toLocaleString('en-US');\n  };\n\n  const pnlColor = (v) => {\n    const n = Number(String(v).replace('%', '').replace(',', '.').trim());\n    if (Number.isNaN(n)) return '#111827';\n    return n < 0 ? '#b91c1c' : '#15803d';\n  };\n\n  const pnlArrow = (v) => {\n    const n = Number(String(v).replace('%', '').replace(',', '.').trim());\n    if (Number.isNaN(n)) return '';\n    return n < 0 ? '▼' : '▲';\n  };\n\n  const drawdownColor = pnlColor(drawdown);\n\n  const posStart = lines.findIndex(l => l.includes('## Posiciones actuales'));\n  const posEnd = lines.findIndex((l, i) => i > posStart && l.startsWith('## '));\n\n  const posLines = posStart >= 0\n    ? lines.slice(posStart + 1, posEnd >= 0 ? posEnd : lines.length)\n    : [];\n\n  const positions = posLines\n    .filter(l => l.startsWith('-'))\n    .map(l => l.replace(/\\*\\*/g, '').trim())\n    .map(l => {\n      const ticker = (l.match(/-?\\s*([A-Z][A-Z0-9.-]*)/) || [])[1] || '';\n      const shares = (l.match(/([0-9.]+)\\s*sh/i) || [])[1] || '';\n      const avg = (l.match(/avg\\s*([0-9.]+)/i) || [])[1] || '';\n      const close = (l.match(/close\\s*([0-9.]+)/i) || [])[1] || '';\n      const mv = (l.match(/mv\\s*([0-9.]+)/i) || [])[1] || '';\n      const pnl = (l.match(/pnl\\s*([-0-9.]+%)/i) || [])[1] || '';\n      return { ticker, shares, avg, close, mv, pnl };\n    })\n    .filter(p => p.ticker);\n\n  const positionsHtml = positions.length\n    ? positions.map(p => `\n      <div style=\"padding:14px 16px;border:1px solid #e5e7eb;border-radius:14px;background:#ffffff;\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;\">\n          <div style=\"font-size:16px;font-weight:800;color:#111827;\">${p.ticker}</div>\n          <div style=\"font-size:14px;font-weight:800;color:${pnlColor(p.pnl)};\">\n            ${pnlArrow(p.pnl)} ${p.pnl || '-'}\n          </div>\n        </div>\n        <div style=\"font-size:13px;color:#374151;line-height:1.6;\">\n          <b>Shares:</b> ${p.shares || '-'}<br>\n          <b>Avg:</b> ${p.avg || '-'}<br>\n          <b>Close:</b> ${p.close || '-'}<br>\n          <b>MV:</b> ${p.mv || '-'}\n        </div>\n      </div>\n    `).join('')\n    : `<div style=\"color:#6b7280;\">Sin posiciones</div>`;\n\n  return `\n  <div style=\"background:#f3f4f6;padding:32px 16px;font-family:Arial,Helvetica,sans-serif;\">\n    <div style=\"max-width:820px;margin:0 auto;\">\n\n      <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:18px;padding:22px 20px;margin-bottom:16px;\">\n        <div style=\"font-size:18px;font-weight:800;color:#111827;margin-bottom:6px;\">\n          📊 QuantBot ${$json.session_label}\n        </div>\n        <div style=\"font-size:13px;color:#6b7280;\">\n          ${$json.run_timestamp}\n        </div>\n      </div>\n\n      <div style=\"display:grid;grid-template-columns:1fr;gap:10px;\">\n\n        <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:16px;padding:14px 16px;\">\n          <div style=\"font-size:12px;color:#6b7280;margin-bottom:6px;\">Equity</div>\n          <div style=\"font-size:16px;font-weight:800;color:#111827;\">${formatMoney(equity)}</div>\n        </div>\n\n        <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:16px;padding:14px 16px;\">\n          <div style=\"font-size:12px;color:#6b7280;margin-bottom:6px;\">Cash</div>\n          <div style=\"font-size:16px;font-weight:800;color:#111827;\">${formatMoney(cash)}</div>\n        </div>\n\n        <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:16px;padding:14px 16px;\">\n          <div style=\"font-size:12px;color:#6b7280;margin-bottom:6px;\">Exposure</div>\n          <div style=\"font-size:16px;font-weight:800;color:#111827;\">${exposure || '-'}</div>\n        </div>\n\n        <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:16px;padding:14px 16px;\">\n          <div style=\"font-size:12px;color:#6b7280;margin-bottom:6px;\">Drawdown</div>\n          <div style=\"font-size:16px;font-weight:800;color:${drawdownColor};\">\n            ${drawdown ? `${pnlArrow(drawdown)} ${drawdown}` : '-'}\n          </div>\n        </div>\n\n      </div>\n\n      <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:18px;padding:18px 20px;margin-top:16px;\">\n        <div style=\"font-size:18px;font-weight:800;color:#111827;margin-bottom:14px;\">\n          Positions\n        </div>\n        <div style=\"display:grid;grid-template-columns:1fr;gap:10px;\">\n          ${positionsHtml}\n        </div>\n      </div>\n\n    </div>\n  </div>\n  `;\n})()\n}}",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
