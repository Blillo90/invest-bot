            {
              "id": "22beeb03-9d6d-4372-be0d-bb006602dd4d",
              "name": "body",
              "value": "={{\n(() => {\n  const sessionLabel = $json.session_label || 'UNKNOWN';\n  const mode = $json.mode || 'UNKNOWN';\n  const timestamp = $json.run_timestamp || $now.toString();\n\n  const errorStage =\n    $json.returncode !== undefined && Number($json.returncode) !== 0\n      ? 'BOT_EXECUTION'\n      : (!$json.data || String($json.data).trim() === '')\n        ? 'EMPTY_REPORT'\n        : 'UNKNOWN_STAGE';\n\n  const raw = JSON.stringify($json, null, 2)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;');\n\n  return `\n  <div style=\"background:#f3f4f6;padding:32px 16px;font-family:Arial,Helvetica,sans-serif;\">\n    <div style=\"max-width:820px;margin:0 auto;\">\n\n      <div style=\"background:#ffffff;border:1px solid #fecaca;border-radius:18px;padding:22px 20px;margin-bottom:16px;\">\n        <div style=\"font-size:18px;font-weight:800;color:#991b1b;margin-bottom:6px;\">\n          ❌ QuantBot Error\n        </div>\n        <div style=\"font-size:13px;color:#6b7280;\">\n          ${timestamp}\n        </div>\n      </div>\n\n      <div style=\"display:grid;grid-template-columns:1fr;gap:10px;\">\n\n        <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:16px;padding:14px 16px;\">\n          <div style=\"font-size:12px;color:#6b7280;margin-bottom:6px;\">Session</div>\n          <div style=\"font-size:16px;font-weight:800;color:#111827;\">${sessionLabel}</div>\n        </div>\n\n        <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:16px;padding:14px 16px;\">\n          <div style=\"font-size:12px;color:#6b7280;margin-bottom:6px;\">Mode</div>\n          <div style=\"font-size:16px;font-weight:800;color:#111827;\">${mode}</div>\n        </div>\n\n        <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:16px;padding:14px 16px;\">\n          <div style=\"font-size:12px;color:#6b7280;margin-bottom:6px;\">Stage</div>\n          <div style=\"font-size:16px;font-weight:800;color:#991b1b;\">${errorStage}</div>\n        </div>\n\n      </div>\n\n      <div style=\"background:#ffffff;border:1px solid #e5e7eb;border-radius:18px;padding:18px 20px;margin-top:16px;\">\n        <div style=\"font-size:18px;font-weight:800;color:#111827;margin-bottom:14px;\">\n          Raw details\n        </div>\n        <pre style=\"white-space:pre-wrap;word-break:break-word;font-size:12px;line-height:1.5;color:#374151;background:#f9fafb;border:1px solid #e5e7eb;border-radius:12px;padding:14px;\">${raw}</pre>\n      </div>\n\n    </div>\n  </div>\n  `;\n})()\n}}",
              "type": "string"
            }
          ]
        },
